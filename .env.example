# Copy this file to .env when you're ready to enable real order notification emails.
# The app is already configured to send order notifications to tylercgady@gmail.com.
# You only need to provide a real sender account here.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sender-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-sender-email@gmail.com
ORDER_NOTIFY_TO=tylercgady@gmail.com
